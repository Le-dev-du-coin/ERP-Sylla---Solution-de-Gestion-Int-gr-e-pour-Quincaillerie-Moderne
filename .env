# Configuration locale avec services Docker
DJANGO_READ_DOT_ENV_FILE=True
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=debug-key-to-be-replaced
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
USE_DOCKER=no

# Base de données (Postgres Docker)
# Utilisation de 127.0.0.1 pour forcer TCP
DATABASE_URL=postgres://maliandevboy:maliandevboy@127.0.0.1:5432/erp_sylla

# Celery / Redis (Redis Docker)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

# Email (Mailpit Docker)
EMAIL_PORT=1025
EMAIL_HOST=127.0.0.1
